 #     - {{ root }}/data:/app/data
 #     - /run/udev:/run/udev:ro
 #   environment:
 #     - TZ=Europe/Berlin
    # devices:
      # Make sure this matched your adapter location
      # - {{ homeassistant_zigbee_dongle_device }}:{{ homeassistant_zigbee_dongle_device }}
  mosquitto:
    image: eclipse-mosquitto:latest
    container_name: mosquitto
    restart: unless-stopped
    lables:
      - traefik.enable=true
      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-mqtt.entrypoints=mqtt
      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-mqtt.rule=Host(`{{ mqtt_domain | mandatory }}`)
      - traefik.http.services.${COMPOSE_PROJECT_NAME}-mqtt.loadbalancer.server.port=1883