networks:
  web:
    external: true

volumes:
  prometheus-data:
  grafana-data:

services:
  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.151.0
    volumes:
      - ./otel/otel-collector-config.yml:/etc/otelcol-contrib/config.yaml:ro
    labels:
      - traefik.enable=true

      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-otel-collector.entrypoints=https
      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-otel-collector.rule=Host(`{{ otel_collector_domain }}`)
      - traefik.http.services.${COMPOSE_PROJECT_NAME}-otel-collector.loadbalancer.server.scheme=h2c
      - traefik.http.services.${COMPOSE_PROJECT_NAME}-otel-collector.loadbalancer.server.port=4317
    networks:
      - web

  prometheus:
    image: prom/prometheus:v3.11.3
    command:
      # These are the image defaults.
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --web.console.libraries=/usr/share/prometheus/console_libraries
      - --web.console.templates=/usr/share/prometheus/consoles
      # This is required to create snapshots.
      - --web.enable-admin-api
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ prometheus_config_directory }}:/etc/prometheus.d/:ro
      - prometheus-data:/prometheus
    labels:
      - traefik.enable=true

      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-prometheus.entrypoints=https
      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-prometheus.rule=Host(`{{ prometheus_domain }}`)
      - traefik.http.services.${COMPOSE_PROJECT_NAME}-prometheus.loadbalancer.server.port=9090
    networks:
      - web
    extra_hosts:
      - "host.docker.internal:host-gateway"
    healthcheck:
      test:
        - CMD
        - wget
        - --server-response
        - --output-document
        - /dev/null
        - http://localhost:9090/
      start_period: 30s
      interval: 5s

  grafana:
    image: grafana/grafana:13.0.1
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - grafana-data:/var/lib/grafana
    environment:
      # The configuration values in the grafana.ini:
      # https://github.com/grafana/grafana/blob/main/conf/sample.ini
      # can be overridden by environment variables prefixed with "GF_", e.g.
      # GF_SECURITY_ADMIN_USER: not-admin
      # GF_SECURITY_ADMIN_PASSWORD: {{ grafana_admin_password }}
      GF_SERVER_ROOT_URL: {{ grafana_url }}
    labels:
      - traefik.enable=true

      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-grafana.entrypoints=https
      - traefik.http.routers.${COMPOSE_PROJECT_NAME}-grafana.rule=Host(`{{ grafana_domain }}`)
      - traefik.http.services.${COMPOSE_PROJECT_NAME}-grafana.loadbalancer.server.port=3000
    networks:
      - web
    healthcheck:
      test:
        - CMD
        - wget
        - -S
        - -O
        - /dev/null
        - http://localhost:3000
      start_period: 5s
      interval: 5s
    depends_on:
      prometheus:
        condition: service_healthy
