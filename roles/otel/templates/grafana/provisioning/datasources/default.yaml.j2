apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    url: http://prometheus:9090
    # https://grafana.com/docs/grafana/latest/administration/provisioning/#json-data
    jsonData:
      httpMethod: POST
      manageAlerts: true
      prometheusType: Prometheus
      cacheLevel: Low
      timeInterval: {{ otel_prometheus_scrape_interval | mandatory }}
